<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:title="Appearance">
        <ListPreference
            app:defaultValue="Default"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme_preference"
            app:title="App Theme"
            app:icon="@drawable/home"
            app:summary="Choose your app theme"
            app:layout="@layout/preference_layout"
            />
    </PreferenceCategory>

    <PreferenceCategory app:title="Notifications">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="daily_reminder"
            app:title="Daily Reminders"
            app:summary="Receive a daily notification reminder"
            app:icon="@drawable/notification_image"
            app:layout="@layout/preference_layout"
            />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="chat_notifications"
            app:title="Chat Notifications"
            app:summary="Receive alerts for new messages"
            app:icon="@drawable/notification_image"
            app:layout="@layout/preference_layout"
            />
    </PreferenceCategory>

    <PreferenceCategory app:title="Account">
        <Preference
            app:key="log_out"
            app:title="Log Out"
            app:summary="Sign out and return to login screen"
            app:icon="@drawable/logout_image"
            app:layout="@layout/preference_layout"/>
    </PreferenceCategory>
</androidx.preference.PreferenceScreen>