<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".UserProfile">

        <androidx.cardview.widget.CardView
            android:id="@+id/userProfilePfpCard"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_margin="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:cardCornerRadius="90dp"
            app:cardBackgroundColor="?attr/cardBgColor">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/user_pfp"
                android:layout_gravity="center"
                android:id="@+id/userProfilePfp"
                />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/textProfileLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@+id/userProfilePfpCard"
            app:layout_constraintTop_toTopOf="@id/userProfilePfpCard"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/txtUserNameProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="20sp"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                tools:text="@tools:sample/full_names" />

            <TextView
                android:id="@+id/txtUserPhoneProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                tools:text="@tools:sample/us_phones" />

            <TextView
                android:id="@+id/txtUserEmailProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="16sp"
                android:textColor="?attr/colorSecondary"
                tools:text="test@gmail.com" />
        </LinearLayout>
        <ImageButton
            android:id="@+id/ivProfileMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/popup_menu"
            android:background="@android:color/transparent"
            android:contentDescription="menu"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="20dp"
            app:tint="?android:attr/textColorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />
        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:backgroundTint="?attr/bottomNavIndicator"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintEnd_toStartOf="@+id/btnAllPostedItems"
            app:layout_constraintStart_toStartOf="@id/userProfilePfpCard"
            app:layout_constraintTop_toBottomOf="@id/userProfilePfpCard"
            />
        <Button
            android:id="@+id/btnAllPostedItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="All Items"
            android:textColor="?android:attr/textColorSecondary"
            android:textStyle="bold"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginEnd="20dp"
            android:layout_marginStart="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnEditProfile"
            app:layout_constraintTop_toTopOf="@id/btnEditProfile"
            />
        <TextView
            android:id="@+id/txtMyItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Items"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24dp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@id/btnEditProfile"
            app:layout_constraintTop_toBottomOf="@id/btnEditProfile"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUserProfile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/txtMyItems"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/txtMyItems"
            android:layout_margin="10dp"
            android:padding="5dp"
            tools:listitem="@layout/item_row"/>
        <TextView
            android:id="@+id/tvEmptyList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item list seems to be empty!"
            android:textSize="25sp"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:drawableBottom="@drawable/empty_list_image"
            app:layout_constraintTop_toBottomOf="@id/txtMyItems"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone"
            />
</androidx.constraintlayout.widget.ConstraintLayout>